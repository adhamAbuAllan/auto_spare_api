CHAT_TYPING_TTL_SECONDS=8
CHAT_HEARTBEAT_INTERVAL_SECONDS=20
CHAT_MAX_MEDIA_BYTES=5242880
CHAT_ALLOWED_MEDIA_TYPES=text/plain,image/jpeg,image/png,image/webp,image/gif,application/pdf,video/mp4,audio/mpeg,audio/ogg
