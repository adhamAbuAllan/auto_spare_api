JWT_SIGNING_KEY=replace-with-a-long-random-signing-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,testserver
TIME_ZONE=UTC
DB_ENGINE=postgres
DB_NAME=auto_spare_db
