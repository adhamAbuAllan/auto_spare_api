@baseUrl = http://127.0.0.1:8000
@contentType = application/json

### Notes
# To use chained requests, run them in order. 
# If you want to run any request directly, set the manual IDs below and use the "manual" versions.

@accessToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ0b2tlbl90eXBlIjoiYWNjZXNzIiwiZXhwIjoxNzc0MTA5NDI4LCJpYXQiOjE3NzQxMDkxMjgsImp0aSI6IjVlN2MzZTA4YjdlMjRlN2E5MzlkMzBlYjJmZWFmY2MwIiwidXNlcl9pZCI6IjEifQ.nzz3sZd_kuCWucACsfwim-ORIlfjxFKR7HD5_C-0Oes
@userId = 2
@partStatusId = 1
@partRequestId = 1
@conversationId = 2
@messageId = 1

### Health
GET {{baseUrl}}/api/health/
Authorization: Bearer {{accessToken}}

### Auth - Login (JWT)
# @name login
POST {{baseUrl}}/api/token/
Content-Type: {{contentType}}

{
  "username": "admin",
  "password": "111111"
}

### Auth - Refresh (JWT)
POST {{baseUrl}}/api/token/refresh/
Content-Type: {{contentType}}

{
  "refresh": "{{login.response.body.refresh}}"
}

### Me - Get Profile
GET {{baseUrl}}/api/me/
Authorization: Bearer {{accessToken}}

### Me - Update Profile
PATCH {{baseUrl}}/api/me/
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "name": "Updated Name",
  "city": "Riyadh"
}

### Users - Create
# @name createUser
POST {{baseUrl}}/api/users/
Content-Type: {{contentType}}

{
  "email": "user1@example.com",
  "username": "user1",
  "name": "User One",
  "phone": "+15551234567",
  "city": "Riyadh",
  "role": "user",
  "rating": null,
  "password": "test1234"
}

### Users - List
GET {{baseUrl}}/api/users/
Authorization: Bearer {{accessToken}}

### Spare Parts - Create
POST {{baseUrl}}/api/spare-parts/
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "name": "Brake Pad2",
  "description": "Front brake pad2 set",
  "price": "199.99"
}

### Spare Parts - List
GET {{baseUrl}}/api/spare-parts/
Authorization: Bearer {{accessToken}}

### Part Request Status - Create
# @name createPartStatus
POST {{baseUrl}}/api/part-request-statuses/
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "code": "open",
  "label": "Open",
  "is_terminal": false
}

### Part Request - Create
# @name createPartRequest
POST {{baseUrl}}/api/part-requests/
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "requester": {{userId}},
  "title": "Need Toyota Corolla 2018 front bumper",
  "description": "Original part preferred, used is fine.",
  "status": {{partStatusId}},
  "city": "Riyadh"
}

### Part Image - Add (multipart, raw boundary)
POST {{baseUrl}}/api/part-images/
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW
Authorization: Bearer {{accessToken}}

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="part_request"

{{partRequestId}}
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="image"; filename="sample_part.jpg"
Content-Type: image/jpeg

< /Volumes/MyDisk/mac/lib/Projects/DjangoProjects/auto_spare_api/fixtures/sample_part.jpg
------WebKitFormBoundary7MA4YWxkTrZu0gW--

### Conversation - Create
# @name createConversation
POST {{baseUrl}}/api/conversations/
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "title": "Bumper Request Chat"
}

### Conversation Participant - Add (manual IDs)
POST {{baseUrl}}/api/conversation-participants/
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "conversation": {{conversationId}},
  "user": {{userId}}
}

### Message - Send (manual)
# @name createMessage
POST {{baseUrl}}/api/messages/
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "conversation": {{conversationId}},
  "sender": {{userId}},
  "message_type": "text",
  "text": "Hi, I need the front bumper for Corolla 2018.",
  "client_timestamp": "2026-03-20T12:00:00Z"
}

### Message Status - Add
POST {{baseUrl}}/api/message-statuses/
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "message": {{messageId}},
  "user": {{userId}},
  "status": "sent"
}

### Part Request - Create (manual IDs)
POST {{baseUrl}}/api/part-requests/
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "requester": {{userId}},
  "title": "Manual request",
  "description": "Manual request description",
  "status": {{partStatusId}},
  "city": "Riyadh"
}

### Part Image - Add (manual IDs, multipart)
POST {{baseUrl}}/api/part-images/
Content-Type: multipart/form-data
Authorization: Bearer {{accessToken}}

part_request: {{partRequestId}}
image: @/absolute/path/to/image.jpg

### Conversation Participant - Add (manual IDs)
POST {{baseUrl}}/api/conversation-participants/
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "conversation": {{conversationId}},
  "user": {{userId}}
}

### Message - Send (manual IDs)
POST {{baseUrl}}/api/messages/
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "conversation": {{conversationId}},
  "sender": {{userId}},
  "message_type": "text",
  "text": "Manual message.",
  "client_timestamp": "2026-03-20T12:00:00Z"
}

### Message Status - Add (manual IDs)
POST {{baseUrl}}/api/message-statuses/
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "message": {{messageId}},
  "user": {{userId}},
  "status": "sent"
}
