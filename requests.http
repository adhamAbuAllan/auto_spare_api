POST {{baseUrl}}/api/part-requests/
Content-Type: {{contentType}}
Authorization: Bearer {{accessToken}}

{
  "requester": {{userId}},
  "title": "Manual request",
  "description": "Manual request description",
  "status": {{partStatusId}},
  "city": "Riyadh"
}

